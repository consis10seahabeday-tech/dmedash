const FASTAPI_BASE = "http://localhost:8000";

// ── ReportPanel ───────────────────────────────────────────────────────────────

type ReportActionStatus = "idle" | "loading" | "success" | "error";

function ReportPanel(): JSX.Element {
  const [reportText, setReportText]       = useState<string>(defaultReport);
  const [loadStatus, setLoadStatus]       = useState<ReportActionStatus>("idle");
  const [sendStatus, setSendStatus]       = useState<ReportActionStatus>("idle");
  const [loadMessage, setLoadMessage]     = useState<string>("");
  const [sendMessage, setSendMessage]     = useState<string>("");

  // ── Load latest report ──────────────────────────────────────────────────────
  const handleLoad = async (): Promise<void> => {
    setLoadStatus("loading");
    setLoadMessage("");
    try {
      const res = await fetch(`${FASTAPI_BASE}/report`);
      if (!res.ok) {
        const text = await res.text();
        setLoadStatus("error");
        setLoadMessage(`Error ${res.status}: ${text}`);
      } else {
        const json = await res.json();
        // Accept { report: "..." } or { data: "..." } or plain string
        const content: string =
          typeof json === "string"
            ? json
            : json?.report ?? json?.data ?? JSON.stringify(json, null, 2);
        setReportText(content);
        setLoadStatus("success");
        setLoadMessage("Report loaded");
      }
    } catch (err) {
      setLoadStatus("error");
      setLoadMessage(err instanceof Error ? err.message : "Request failed");
    }
    setTimeout(() => { setLoadStatus("idle"); setLoadMessage(""); }, 4000);
  };

  // ── Send report ─────────────────────────────────────────────────────────────
  const handleSend = async (): Promise<void> => {
    setSendStatus("loading");
    setSendMessage("");
    try {
      const res = await fetch(`${FASTAPI_BASE}/send-report`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ report: reportText }),
      });
      if (!res.ok) {
        const text = await res.text();
        setSendStatus("error");
        setSendMessage(`Error ${res.status}: ${text}`);
      } else {
        const json = await res.json().catch(() => ({}));
        setSendStatus("success");
        setSendMessage(json?.message ?? "Sent successfully");
      }
    } catch (err) {
      setSendStatus("error");
      setSendMessage(err instanceof Error ? err.message : "Request failed");
    }
    setTimeout(() => { setSendStatus("idle"); setSendMessage(""); }, 4000);
  };

  // ── Spinner SVG ─────────────────────────────────────────────────────────────
  const Spinner = (): JSX.Element => (
    <svg className="animate-spin w-3 h-3" viewBox="0 0 24 24" fill="none">
      <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4" />
      <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z" />
    </svg>
  );

  return (
    <>
      <header className="flex items-center justify-between px-8 py-5 border-b border-gray-100 shrink-0">
        <div>
          <div className="flex items-center gap-2.5">
            <h1 className="text-xs font-semibold tracking-widest uppercase text-gray-800 m-0">
              Report
            </h1>
            <span className="text-[11px] px-2.5 py-0.5 rounded text-gray-400 border border-gray-200 bg-gray-50">
              {formattedDate}
            </span>
          </div>
          <p className="text-[11px] text-gray-400 mt-0.5">Editable health check report</p>
        </div>

        {/* Action buttons */}
        <div className="flex items-center gap-2">

          {/* Load feedback */}
          {loadStatus === "success" && (
            <span className="text-[11px] text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">
              ✓ {loadMessage}
            </span>
          )}
          {loadStatus === "error" && (
            <span className="text-[11px] text-red-500 bg-red-50 border border-red-200 px-2 py-0.5 rounded-full max-w-[160px] truncate" title={loadMessage}>
              ✕ {loadMessage}
            </span>
          )}

          {/* Load button */}
          <button
            onClick={handleLoad}
            disabled={loadStatus === "loading"}
            className="flex items-center gap-1.5 px-4 py-1.5 rounded text-[12px] cursor-pointer transition-all duration-150 disabled:opacity-60 disabled:cursor-not-allowed border"
            style={{
              background: "transparent",
              color: loadStatus === "error" ? "#b91c1c" : "#1a3a5c",
              borderColor: loadStatus === "error" ? "#fca5a5" : "#c3d4e6",
            }}
            onMouseEnter={(e: React.MouseEvent<HTMLButtonElement>) => {
              e.currentTarget.style.background = "#f0f5fa";
            }}
            onMouseLeave={(e: React.MouseEvent<HTMLButtonElement>) => {
              e.currentTarget.style.background = "transparent";
            }}
          >
            {loadStatus === "loading" ? <><Spinner /> Loading…</> : "↓ Load latest"}
          </button>

          {/* Send feedback */}
          {sendStatus === "success" && (
            <span className="text-[11px] text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">
              ✓ {sendMessage}
            </span>
          )}
          {sendStatus === "error" && (
            <span className="text-[11px] text-red-500 bg-red-50 border border-red-200 px-2 py-0.5 rounded-full max-w-[160px] truncate" title={sendMessage}>
              ✕ {sendMessage}
            </span>
          )}

          {/* Send button */}
          <button
            onClick={handleSend}
            disabled={sendStatus === "loading"}
            className="flex items-center gap-1.5 px-4 py-1.5 rounded text-[12px] text-white cursor-pointer transition-all duration-150 disabled:opacity-60 disabled:cursor-not-allowed"
            style={{ background: sendStatus === "error" ? "#b91c1c" : "#1a3a5c" }}
            onMouseEnter={(e: React.MouseEvent<HTMLButtonElement>) => {
              if (sendStatus !== "loading") e.currentTarget.style.background = sendStatus === "error" ? "#991b1b" : "#245080";
            }}
            onMouseLeave={(e: React.MouseEvent<HTMLButtonElement>) => {
              e.currentTarget.style.background = sendStatus === "error" ? "#b91c1c" : "#1a3a5c";
            }}
          >
            {sendStatus === "loading" ? <><Spinner /> Sending…</> : "↑ Send report"}
          </button>

          <CopyButton getText={() => reportText} />
        </div>
      </header>

      <div className="flex-1 overflow-y-auto px-8 py-6">
        <textarea
          value={reportText}
          onChange={(e: React.ChangeEvent<HTMLTextAreaElement>) =>
            setReportText(e.target.value)
