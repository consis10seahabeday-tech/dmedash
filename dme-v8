async function fetchMails(): Promise<MailMessage[]> {
  const res = await fetch(`${FASTAPI_BASE}/mails`);
  if (!res.ok) throw new Error(`Failed to fetch mails: ${res.status}`);
  const json = await res.json();
  // Expects { mails: MailMessage[] } or MailMessage[]
